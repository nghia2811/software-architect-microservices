# Copy this file to .env.production on your VPS and fill in real values.
# This file is checked into git as a template — never commit the real .env.production.

# Docker image registry (GitHub Container Registry)
# Format: ghcr.io/<github-username>
REGISTRY=ghcr.io/your-github-username

# Git commit SHA used as image tag (set automatically by CI)
IMAGE_TAG=latest

# PostgreSQL production password
POSTGRES_PASSWORD=change_me_strong_password_here

# GHCR credentials (used by deploy.sh to pull images)
GHCR_USER=your-github-username
GHCR_TOKEN=ghp_your_personal_access_token_here
